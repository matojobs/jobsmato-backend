	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-set base URL if not already set",
					"if (!pm.collectionVariables.get(\"base_url\")) {",
					"    pm.collectionVariables.set(\"base_url\", \"https://api.jobsmato.com/api\");",
					"}"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Global test script",
					"pm.test(\"Response time is less than 5000ms\", function () {",
					"    pm.expect(pm.response.responseTime).to.be.below(5000);",
					"});",
					"",
					"// Check for authentication errors",
					"if (pm.response.code === 401) {",
					"    pm.test(\"Authentication failed - Check your auth_token variable\", function () {",
					"        pm.expect.fail(\"Invalid or missing JWT token. Please set the auth_token variable.\");",
					"    });",
					"}"
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "https://api.jobsmato.com/api",
			"type": "string"
		},
		{
			"key": "auth_token",
			"value": "",
			"type": "string",
			"description": "JWT authentication token. Get this from the login endpoint."
		},
		{
			"key": "application_id",
			"value": "",
			"type": "string",
			"description": "Application ID (auto-set when creating an application)"
		},
		{
			"key": "job_id",
			"value": "",
			"type": "string",
			"description": "Job ID (auto-set when creating an application)"
		}
	]
}


